<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:background="@color/community_gray_bg"
              android:orientation="horizontal">

    <RelativeLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/foot_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="-20dp"
            android:src="@drawable/community_home_girl_icon"/>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="0dip"
        android:layout_height="wrap_content"
        android:layout_weight="0.3"
        android:paddingTop="15dip">

        <ProgressBar
            android:id="@+id/foot_load"
            android:layout_width="25dip"
            android:layout_height="25dip"/>
    </LinearLayout>

    <RelativeLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/foot_text_01"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_centerHorizontal="true"
                android:layout_weight="1"
                android:background="@color/community_gray_bg"
                android:gravity="center"
                android:paddingTop="5dp"
                android:text="@string/community_home_loadmore_tip1"
                android:textColor="@color/llgray"/>

            <TextView
                android:id="@+id/foot_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/foot_text_01"
                android:layout_weight="1"
                android:background="@color/community_gray_bg"
                android:gravity="center"
                android:paddingBottom="5dp"
                android:text="@string/community_home_loadmore_tip2"
                android:textColor="@color/llgray"/>
        </RelativeLayout>
    </RelativeLayout>
</LinearLayout>