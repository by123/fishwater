<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    android:paddingLeft="@dimen/space_10"
    android:paddingRight="@dimen/space_10">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:textColor="@color/record_list_items_content">

        <TextView
            android:id="@+id/record_window_list_items_title"
            android:layout_width="@dimen/record_window_list_items_title_width"
            android:layout_height="match_parent"
            android:gravity="left|center_vertical"
            android:textColor="@color/record_list_items_content" />

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <CheckBox
                android:id="@+id/record_window_list_items_btn_prop"
                style="@style/RecordCheckBox"
                android:drawableRight="@drawable/record_window_list_items_prop" />

            <GridView
                android:id="@+id/record_window_list_items_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="0dp"
                android:scrollbars="none" />

            <CheckBox
                android:id="@+id/record_window_list_items_btn_heat"
                style="@style/RecordCheckBox"
                android:drawableRight="@drawable/record_window_list_items_heat" />
        </FrameLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="@dimen/divider_height"
        android:layout_gravity="bottom"
        android:background="@color/record_list_items_side" />
</LinearLayout>