<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/community_gray_line" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="@color/white"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/more_see"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/account_selector_option"
            android:drawableTop="@drawable/more_see"
            android:gravity="center"
            android:padding="5dp"
            android:text="倒序查看"
            android:textColor="@color/llgray"
            android:textSize="@dimen/space_13" />


        <TextView
            android:id="@+id/more_collect"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/account_selector_option"
            android:drawableTop="@drawable/community_collect_bg"
            android:gravity="center"
            android:padding="5dp"
            android:text="收藏"
            android:textColor="@color/community_collect_color"
            android:textSize="@dimen/space_13" />


        <TextView
            android:id="@+id/more_share"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/account_selector_option"
            android:drawablePadding="5dp"
            android:drawableTop="@drawable/more_share"
            android:gravity="center"
            android:padding="5dp"
            android:text="分享"
            android:textColor="@color/llgray"
            android:textSize="@dimen/space_13" />


        <TextView
            android:id="@+id/more_report"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/account_selector_option"
            android:drawablePadding="5dp"
            android:drawableTop="@drawable/more_report"
            android:gravity="center"
            android:padding="5dp"
            android:text="举报"
            android:textColor="@color/llgray"
            android:textSize="@dimen/space_13" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/community_gray_line" />

    <TextView
        android:id="@+id/cancel_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/account_selector_option"
        android:gravity="center"
        android:padding="@dimen/space_20"
        android:textSize="@dimen/space_16"
        android:text="@string/community_btn_cancel"
        android:textColor="@color/community_pink" />
</LinearLayout>
