<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/homepage_test_content_mask">

    <ImageView
        android:id="@+id/photo_picker_image_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"/>

    <View
        android:id="@+id/photo_picker_mask_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/homepage_test_content_mask"/>

    <ImageView
        android:id="@+id/photo_picker_checked_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="right|top"
        android:layout_marginRight="4dp"
        android:layout_marginTop="4dp"
        android:src="@drawable/checkbox_green_checked"
        android:visibility="invisible"/>

</FrameLayout>