<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:id="@+id/ta_she_secretary_good"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/space_10"
    android:background="@color/white"
    android:orientation="horizontal"
    android:padding="@dimen/space_10"
    android:visibility="gone">

    <com.facebook.drawee.view.SimpleDraweeView
        android:id="@+id/ta_she_secretary_good_image"
        android:layout_width="@dimen/space_60"
        android:layout_height="@dimen/space_60"
        android:layout_marginRight="@dimen/space_10"
        android:layout_gravity="center"
        android:scaleType="fitXY"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/ta_she_secretary_good_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/tab_text_default_color"
            android:textSize="@dimen/space_14"/>

        <TextView
            android:id="@+id/ta_she_secretary_good_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_5"
            android:layout_marginTop="@dimen/space_5"
            android:textColor="@color/price_text_color"
            android:textSize="@dimen/space_14"/>

        <com.sjy.ttclub.widget.AlphaTextView
            android:id="@+id/ta_she_secretary_good_send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/account_upgrade_bg"
            android:gravity="center"
            android:paddingLeft="@dimen/space_5"
            android:paddingRight="@dimen/space_5"
            android:text="发送宝贝"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/space_12"/>

    </LinearLayout>
</LinearLayout>
