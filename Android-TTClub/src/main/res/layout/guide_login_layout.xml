<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.sjy.ttclub.guide.GuideImagesView
        android:id="@+id/guide_images_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="@dimen/space_20"
        android:orientation="horizontal">

        <com.sjy.ttclub.widget.AlphaTextView
            android:id="@+id/guide_register_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="@dimen/space_48"
            android:layout_marginRight="@dimen/space_13"
            android:layout_weight="1"
            android:background="@drawable/button_circle_board_bg"
            android:gravity="center"
            android:paddingBottom="@dimen/space_10"
            android:paddingLeft="@dimen/space_42"
            android:paddingRight="@dimen/space_42"
            android:paddingTop="@dimen/space_10"
            android:text="@string/account_signup_signup"
            android:textColor="@color/white"
            android:textSize="@dimen/space_15" />

        <com.sjy.ttclub.widget.AlphaTextView
            android:id="@+id/guide_login_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="@dimen/space_13"
            android:layout_marginRight="@dimen/space_48"
            android:layout_weight="1"
            android:background="@drawable/button_circle_board_bg"
            android:gravity="center"
            android:padding="@dimen/space_10"
            android:paddingBottom="@dimen/space_10"
            android:paddingLeft="@dimen/space_42"
            android:paddingRight="@dimen/space_42"
            android:paddingTop="@dimen/space_10"
            android:text="@string/account_login_login"
            android:textColor="@color/white"
            android:textSize="@dimen/space_15" />
    </LinearLayout>
</FrameLayout>