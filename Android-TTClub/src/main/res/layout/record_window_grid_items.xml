<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
             android:layout_width="match_parent"
             android:layout_height="match_parent"
             android:background="@color/white"
             android:orientation="vertical">

    <CheckBox
        android:id="@+id/record_window_grid_items_ckb"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="@dimen/space_15"
        android:layout_marginTop="@dimen/space_15"
        android:background="@drawable/record_window_list_items_btn"
        android:button="@android:color/transparent"
        android:gravity="center"
        android:padding="0dp"/>

    <TextView
        android:id="@+id/record_window_grid_items_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="right|center"
        android:focusable="false"
        android:gravity="center"
        android:paddingLeft="@dimen/space_3"
        android:textColor="@color/record_list_items_content"/>

</FrameLayout>