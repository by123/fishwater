<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <GridView
        android:id="@+id/photo_picker_gridview"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:background="@color/white"
        android:horizontalSpacing="@dimen/photo_picker_gap"
        android:numColumns="@integer/photo_picker_column_num"
        android:verticalSpacing="@dimen/photo_picker_gap"/>

    <TextView
        android:id="@+id/photo_picker_no_photo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/photo_picker_loading"
        android:textColor="@color/black"
        android:textSize="@dimen/space_18"
        android:visibility="visible"/>

</FrameLayout>