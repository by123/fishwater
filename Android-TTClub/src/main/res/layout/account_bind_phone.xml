<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical" >

    <View
        style="@style/account_line_style"
        android:paddingTop="@dimen/space_15" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:orientation="vertical" >

        <EditText
            android:id="@+id/account_bind_phone_phone"
            style="@style/account_edit"
            android:digits="0123456789"
            android:hint="@string/account_login_input_phone_hint"
            android:maxLength="11"
            android:paddingLeft="15dp"/>

        <View
            style="@style/account_line_style"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content" >

            <EditText
                android:id="@+id/account_bind_phone_code"
                style="@style/account_edit"
                android:layout_weight="1"
                android:digits="0123456789"
                android:hint="@string/account_retrieve_password_code_hint"
                android:maxLength="4"
                android:paddingLeft="15dp"/>

            <TextView
                android:id="@+id/account_bind_phone_get_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="15dp"
                android:background="@drawable/account_not_click"
                android:gravity="center"
                android:padding="@dimen/space_5"
                android:text="@string/account_signup_get_code"
                android:textColor="@color/white"
                android:textSize="@dimen/space_13"/>

        </LinearLayout>

        <View
            style="@style/account_line_style"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_5"
            android:layout_marginLeft="@dimen/space_15"
            android:layout_marginRight="@dimen/space_15"
            android:layout_marginTop="@dimen/space_5"
            android:text="@string/account_bind_phone_notice"
            android:textColor="@color/title_text_color"
            android:textSize="@dimen/space_13" />

        <Button
            android:id="@+id/account_bind_phone_bind"
            style="@style/account_login_button"
            android:background="@drawable/account_not_click"
            android:text="@string/account_login_bind_phone" />

        <Button
            android:id="@+id/account_bind_phone_pass"
            style="@style/account_login_button"
            android:background="@drawable/account_selector_clickable_bg"
            android:text="@string/account_bind_phone_pass" />
    </LinearLayout>

</LinearLayout>