<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:id="@+id/rl_refresh_header"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/refresh_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center_vertical"
        android:text="下拉刷新"
        android:textColor="@color/llgray"
        android:textSize="@dimen/space_13"/>

    <ImageView
        android:id="@+id/refresh_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginRight="10dp"
        android:layout_toLeftOf="@+id/refresh_text"
        android:src="@drawable/new_refresh_13"
        android:visibility="visible"/>

    <ImageView
        android:id="@+id/refreshing_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginRight="10dp"
        android:layout_toLeftOf="@+id/refresh_text"
        android:src="@anim/loading"
        android:visibility="gone"/>


</RelativeLayout>
