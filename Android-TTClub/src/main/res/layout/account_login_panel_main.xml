<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:id="@+id/ll_login_panel"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:minHeight="200dp"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tv_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="@dimen/space_22"
        android:layout_marginTop="@dimen/space_22"
        android:text="想搞更多？来登录嘛"
        android:textColor="#0d0d0d"
        android:textSize="@dimen/space_19"/>

    <GridView
        android:id="@+id/lv_contents"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:horizontalSpacing="@dimen/space_10"
        android:numColumns="3"
        android:verticalSpacing="@dimen/space_10"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_gravity="center"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginTop="@dimen/space_21"
        android:background="#e5e5e5"/>

    <TextView
        android:id="@+id/tv_native_login"
        android:layout_width="match_parent"
        android:layout_height="@dimen/space_56"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/share_platform_item_bg"
        android:gravity="center"
        android:text="手机登录"
        android:textColor="#6a6a6a"
        android:textSize="@dimen/space_14"/>
</LinearLayout>
