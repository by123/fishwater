<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/space_235"
    android:background="@color/record_list_items_bg"
    android:orientation="vertical">

    <TextView
        android:id="@+id/record_specimen_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/space_40"
        android:textColor="@color/shopping_items_title_color"
        android:textSize="@dimen/space_15"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/space_2"
        android:text="@string/record_self_bottom_text"
        android:textColor="@color/shopping_items_title_color"
        android:textSize="@dimen/space_15"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_30"
        android:layout_marginLeft="@dimen/space_30"
        android:layout_marginRight="@dimen/space_30"
        android:layout_marginTop="@dimen/space_40">

        <com.sjy.ttclub.widget.AlphaTextView
            android:id="@+id/record_bottom_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"

            android:background="@drawable/button_red_bg"
            android:gravity="center"
            android:paddingBottom="@dimen/space_10"
            android:paddingTop="@dimen/space_10"
            android:text="@string/record_data_share_discuss"
            android:textColor="@color/white"
            android:textSize="@dimen/space_18"/>

        <include
            layout="@layout/share_bottom_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"/>
    </FrameLayout>


</LinearLayout>