<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/order_address_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/order_selector_option"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/space_10"
        android:background="@drawable/shopping_address">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_5"
            android:orientation="horizontal"
            android:paddingLeft="@dimen/space_25">

            <ImageView
                android:layout_width="@dimen/space_25"
                android:layout_height="@dimen/space_25"
                android:src="@drawable/shopping_address_ic" />

            <TextView
                android:id="@+id/order_address_receiver"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_3"
                android:layout_weight="1"
                android:paddingLeft="@dimen/space_5"
                android:text="@string/order_address_add"
                android:textColor="@color/shopping_items_other_color"
                android:textSize="@dimen/space_15" />

            <TextView
                android:id="@+id/order_address_mobile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_3"
                android:layout_weight="1"
                android:gravity="right"
                android:paddingLeft="@dimen/space_5"
                android:paddingRight="@dimen/space_25"
                android:textColor="@color/shopping_items_other_color"
                android:textSize="@dimen/space_15" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginTop="@dimen/space_50"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingLeft="@dimen/space_25"
            android:paddingRight="@dimen/space_25">

            <TextView
                android:id="@+id/order_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="left"
                android:lineSpacingExtra="@dimen/space_1"
                android:maxLines="2"
                android:textColor="@color/shopping_items_other_color"
                android:textSize="@dimen/space_15" />

            <ImageView
                android:id="@+id/order_address_add"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_20"
                android:src="@drawable/shopping_address_add"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>