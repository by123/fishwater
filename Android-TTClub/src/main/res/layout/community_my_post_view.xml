<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:fresco="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/account_selector_option"
    android:orientation="vertical">
    <!--<View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/gray_line" />-->

    <TextView
        android:id="@+id/my_community_card_theme"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:layout_marginTop="15dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/black"
        android:textSize="@dimen/space_15" />

    <TextView
        android:id="@+id/my_community_card_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:layout_marginTop="15dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/llgray"
        android:textSize="@dimen/space_13"
        android:visibility="visible" />

    <LinearLayout
        android:id="@+id/images_ll_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:layout_marginTop="15dp"
        android:orientation="horizontal">

        <com.facebook.drawee.view.SimpleDraweeView
            android:id="@+id/card_image1"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1.0"
            fresco:backgroundImage="@color/llgray" />

        <com.facebook.drawee.view.SimpleDraweeView
            android:id="@+id/card_image2"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:layout_weight="1.0"
            fresco:backgroundImage="@color/llgray" />

        <com.facebook.drawee.view.SimpleDraweeView
            android:id="@+id/card_image3"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1.0"
            fresco:backgroundImage="@color/llgray" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/post_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:singleLine="true"
            android:text="1111111"
            android:textColor="@color/community_llgray"
            android:textSize="@dimen/space_10" />

        <TextView
            android:id="@+id/my_card_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="5dp"
            android:gravity="center"
            android:padding="2dp"
            android:text="审核状态"
            android:textColor="@color/community_pink"
            android:textSize="@dimen/space_10" />

        <TextView
            android:id="@+id/isAnony"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/space_16"
            android:gravity="right"
            android:text="@string/shopping_product_anony"
            android:textColor="#999999"
            android:textSize="@dimen/space_11" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:background="@color/community_gray_line" />
</LinearLayout>
