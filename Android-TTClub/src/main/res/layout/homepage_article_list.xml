<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
             android:layout_width="match_parent"
             android:layout_height="match_parent"
             android:background="@color/white">


    <in.srain.cube.views.ptr.PtrClassicFrameLayout
        android:id="@+id/homepage_article_list_ptr"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.sjy.ttclub.loadmore.LoadMoreListViewContainer
            android:id="@+id/homepage_article_list_loadmore"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ListView
                android:id="@+id/homepage_article_detail_listview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@null"
                android:dividerHeight="0px"
                android:drawSelectorOnTop="true"
                android:fastScrollEnabled="false"
                android:listSelector="@drawable/default_listview_seletor"/>
        </com.sjy.ttclub.loadmore.LoadMoreListViewContainer>
    </in.srain.cube.views.ptr.PtrClassicFrameLayout>

    <com.sjy.ttclub.widget.LoadingLayout
        android:id="@+id/homepage_article_list_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</FrameLayout>