<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/order_main_goods_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/space_05"
            android:background="@color/shopping_common_line"></View>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/space_10"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="@string/order_goods_title"
                android:textColor="@color/shopping_items_other_color"
                android:textSize="@dimen/space_12" />

            <TextView
                android:id="@+id/order_main_goods_sum"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="right"
                android:textColor="@color/shopping_items_other_color"
                android:textSize="@dimen/space_12" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/space_05"
            android:background="@color/shopping_common_line"></View>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="horizontal"
        android:padding="@dimen/space_5">

        <com.facebook.drawee.view.SimpleDraweeView
            android:id="@+id/order_main_goods_img"
            android:layout_width="@dimen/space_100"
            android:layout_height="@dimen/space_100"
            android:layout_gravity="left" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="@dimen/space_5"
            android:orientation="vertical"
            android:padding="@dimen/space_5">

            <TextView
                android:id="@+id/order_main_goods_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/shopping_items_title_color"
                android:textSize="@dimen/space_16" />

            <TextView
                android:id="@+id/order_main_goods_spec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_5"
                android:textColor="@color/shopping_items_other_color"
                android:textSize="@dimen/space_12" />

            <ImageView
                android:id="@+id/order_main_goods_panic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_5"
                android:gravity="center"
                android:src="@drawable/product_detail_icon_welfare"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_5"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/order_main_goods_count"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:textColor="@color/shopping_items_other_color"
                    android:textSize="@dimen/space_12" />

                <TextView
                    android:id="@+id/order_main_goods_price"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="right"
                    android:textColor="@color/order_price_text"
                    android:textSize="@dimen/space_16" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/space_05"
        android:background="@color/shopping_common_line"></View>
</LinearLayout>